# ==========================================================
# Firebase config — ສຳລັບ Login ທີມ + ຂໍ້ມູນຮ່ວມກັນ
# ----------------------------------------------------------
# ວິທີໄດ້ຄ່າເຫລົ່ານີ້: ອ່ານ FIREBASE_SETUP.md
#
# ໝາຍເຫດ: ຖ້າບໍ່ຕັ້ງຄ່າເຫລົ່ານີ້ ແອັບຈະເຮັດວຽກແບບ localStorage
# ຄືເກົ່າ (ບໍ່ມີ Login, ຂໍ້ມູນຢູ່ໃນເຄື່ອງແຕ່ລະຄົນ) — ບໍ່ error.
#
# ວິທີໃຊ້: ກັອບໄຟລ໌ນີ້ເປັນ .env ແລ້ວໃສ່ຄ່າຈິງ
#   cp .env.example .env
# ==========================================================

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ອີເມວ admin (ຄັ່ນດ້ວຍ comma ຖ້າມີຫລາຍຄົນ) — admin ເທົ່ານັ້ນທີ່ເພີ່ມພະນັກງານໄດ້
# ຕົວຢ່າງ: VITE_ADMIN_EMAILS=boss@khopkhua.la,manager@khopkhua.la
# ຖ້າປ່ອຍວ່າງ: ທຸກຄົນທີ່ login ຈະຖືກຖືວ່າເປັນ admin (ສະດວກຕອນເລີ່ມ)
VITE_ADMIN_EMAILS=
